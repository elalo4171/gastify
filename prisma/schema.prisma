generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Categoria {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre            String
  emoji             String
  es_predeterminada Boolean    @default(false)
  visible           Boolean    @default(true)
  user_id           String?    @db.Uuid
  created_at        DateTime   @default(now()) @db.Timestamptz()
  registros         Registro[]

  @@map("categorias")
}

model Registro {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipo          String
  monto         Decimal    @db.Decimal(12, 2)
  descripcion   String
  categoria_id  String?    @db.Uuid
  fecha         DateTime   @db.Date
  user_id       String?    @db.Uuid
  created_at    DateTime   @default(now()) @db.Timestamptz()
  categoria     Categoria? @relation(fields: [categoria_id], references: [id], onDelete: SetNull)

  @@index([fecha(sort: Desc)], map: "idx_registros_fecha")
  @@index([tipo], map: "idx_registros_tipo")
  @@index([user_id], map: "idx_registros_user")
  @@map("registros")
}
